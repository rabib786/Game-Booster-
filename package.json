{
  "name": "nexus-booster",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "vite:dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:exe": "npm run build && cd booster_app_export && python -m PyInstaller --noconsole --onefile --add-data \"web:web\" main.py",
    "python:start": "cd booster_app_export && python main.py",
    "preview": "vite preview",
    "clean": "rm -rf dist booster_app_export/web booster_app_export/build booster_app_export/dist",
    "lint": "tsc --noEmit",
    "test:ui": "vitest run",
    "test:backend": "cd booster_app_export && python -m pytest test_main.py"
  },
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^5.0.4",
    "happy-dom": "^20.9.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.546.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-hot-toast": "^2.6.0",
    "react-window": "1.8.10",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^24.0.0",
    "pytest-mock": "^0.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^4.1.5"
  }
}
